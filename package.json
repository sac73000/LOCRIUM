{
  "name": "locrium",
  "version": "1.1.0",
  "description": "Privacy-Focused Desktop Browser",
  "main": "src/main.js",
  "author": "Locrium Technologies",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:release": "electron-builder --win nsis portable --x64 && node scripts/clean-dist.js",
    "build:installer": "electron-builder --win nsis --x64",
    "build:portable": "electron-builder --win portable --x64",
    "build:unpack": "electron-builder --win dir --x64",
    "sign": "node scripts/run-sign.js",
    "version:patch": "node scripts/version-bump.js patch",
    "version:minor": "node scripts/version-bump.js minor",
    "version:major": "node scripts/version-bump.js major",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.locrium.browser",
    "productName": "LOCRIUM",
    "copyright": "Copyright © 2025 Locrium Technologies",
    "afterPack": "scripts/afterPack.js",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "resources/**/*",
      "!**/node_modules/**",
      "!**/dist/**"
    ],
    "win": {
      "executableName": "Locrium",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": "scripts/sign.js",
      "fileAssociations": [
        {
          "ext": [
            "html",
            "htm"
          ],
          "name": "HTML Document",
          "description": "Open with LOCRIUM Browser",
          "role": "Viewer"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "artifactName": "LocriumSetup.exe",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LOCRIUM",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "Locrium.exe"
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "your-github-username",
        "repo": "locrium"
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "mammoth": "^1.7.2",
    "pdf-parse": "^1.1.1",
    "turndown": "^7.1.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "rcedit": "^1.1.1"
  }
}
